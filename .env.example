# ==============================================================================
#  MonaJent — Template de variables d'environnement
#
#  LOCAL  : cp .env.example .env
#  PROD   : injecter ces variables via l'interface Dokploy
#
#  NE JAMAIS COMMITER .env dans Git !
# ==============================================================================

# ── Django ────────────────────────────────────────────────────────────────────
DEBUG=True
SECRET_KEY=CHANGE_ME_generate_with_python3_-c_"import_secrets;print(secrets.token_urlsafe(50))"
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Base de données ──────────────────────────────────────────────────────────
# Vide = SQLite (dev) — En prod : postgres://user:password@host:5432/dbname
DATABASE_URL=

# ── Redis ────────────────────────────────────────────────────────────────────
# Vide = LocMemCache (dev) — En prod : redis://:password@host:6379/0
REDIS_URL=

# ── CORS / CSRF ──────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173

# ── Cookies ──────────────────────────────────────────────────────────────────
AUTH_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax

# ── HTTPS / HSTS ─────────────────────────────────────────────────────────────
SECURE_SSL_REDIRECT=False

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# Hostinger : smtp.hostinger.com / port 465 / SSL
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
EMAIL_HOST_USER=info@monajent.com
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=MonaJent <info@monajent.com>
SERVER_EMAIL=info@monajent.com

# ── Orange SMS A2P ───────────────────────────────────────────────────────────
ORANGE_API_BASE_URL=https://api.orange.com
ORANGE_CLIENT_ID=
ORANGE_CLIENT_SECRET=
ORANGE_SENDER_ADDRESS=tel:+2250000000000
ORANGE_SENDER_NAME=
ORANGE_DEFAULT_COUNTRY_CODE=+225

# ── D7 Verify (OTP SMS) ─────────────────────────────────────────────────────
D7_API_BASE_URL=https://api.d7networks.com
D7_API_TOKEN=
D7_ORIGINATOR=Monajent

# ── Paystack ─────────────────────────────────────────────────────────────────
# simulation = pas d'appel externe (dev) | paystack = Paystack live/test
PAYMENT_GATEWAY=simulation
# Dev: sk_test_xxx / pk_test_xxx | Prod: sk_live_xxx / pk_live_xxx
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# ── URLs de paiement ────────────────────────────────────────────────────────
# Prod: https://api.monajent.com (domaine backend)
PAYMENT_WEBHOOK_BASE_URL=http://localhost:8000
# Prod: https://monajent.com/home/packs (domaine frontend)
PAYMENT_DEFAULT_RETURN_URL=http://localhost:5173/home/packs

# ── Cloudflare R2 (stockage médias) ──────────────────────────────────────────
USE_R2=False
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT_URL=

# ── CSP ──────────────────────────────────────────────────────────────────────
ENABLE_CSP=False

# ── Teaser ───────────────────────────────────────────────────────────────────
TEASER_SECONDS=15

# ── Celery ───────────────────────────────────────────────────────────────────
# Vide = mode eager (synchrone, dev) — En prod : redis://:password@host:6379/0
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# ── Sentry (monitoring — optionnel) ──────────────────────────────────────────
SENTRY_DSN=
